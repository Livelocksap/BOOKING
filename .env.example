# Usada solo por la CLI de Prisma (migraciones) contra una base SQLite local.
DATABASE_URL="file:./prisma/dev.db"

# Usada en tiempo de ejecucion por la app (lib/db.ts) via el adaptador libSQL.
# En local puede apuntar al mismo archivo SQLite que DATABASE_URL.
# En produccion (Vercel), apunta a tu base de datos Turso, ej:
#   TURSO_DATABASE_URL="libsql://tu-base-org.turso.io"
TURSO_DATABASE_URL="file:./prisma/dev.db"
TURSO_AUTH_TOKEN=""

# Clave para cifrar la cookie de sesion (iron-session). Minimo 32 caracteres.
# Generar con: openssl rand -base64 32
SESSION_PASSWORD=""

# Credenciales del socio admin inicial, usadas por prisma/seed.ts
ADMIN_USERNAME="admin"
ADMIN_PASSWORD=""
